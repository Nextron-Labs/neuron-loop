{
  "tiers": {
    "coder": {
      "model": "anthropic/claude-sonnet-4-6",
      "role": "coder"
    },
    "tier1": [
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6",
        "label": "sonnet"
      },
      {
        "provider": "openai",
        "model": "gpt-5.4",
        "label": "gpt54"
      }
    ],
    "tier2": [
      {
        "provider": "ollama-cloud",
        "model": "glm-5:cloud",
        "label": "glm5"
      },
      {
        "provider": "openrouter",
        "model": "auto",
        "label": "openrouter"
      }
    ]
  },
  "gate": {
    "auto_fix_threshold": 2,
    "tier1_single_action": "fix",
    "tier2_single_action": "skip_unless_critical"
  },
  "loop": {
    "max_iterations": 5,
    "max_coder_rounds": 20,
    "convergence_threshold": 0,
    "timeout_seconds": 3600
  },
  "test": {
    "command": "cd /home/neo/.openclaw/workspace/projects/thunderstorm-collector-lua && bash test/run-tests.sh",
    "before_review": true,
    "after_fix": true
  },
  "output": {
    "dir": "./runs",
    "keep_intermediates": true,
    "verbose": true
  }
}